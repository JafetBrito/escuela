# Every file in here is a Vite build output with a content hash in its
# filename (e.g. index-D5gIIv0K.js) — a new deploy always gets new filenames,
# so an old cached copy is never served for new code. Safe to cache forever.
# Kept in its own directory (instead of a global *.js/*.css rule in the
# parent .htaccess) so it can never shadow the no-cache rule that index.html/
# sw.js/manifest.webmanifest need — see ../.htaccess.
<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable"
</IfModule>
