# SPA fallback for Apache-based hosting (e.g. Hostinger): serve index.html
# for any route that isn't a real file/folder, so React Router can handle it.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ---------------------------------------------------------------------------
# Cache-Control — the other half of the auto-update system (see main.jsx,
# which polls the service worker for updates every 60s). That poll is useless
# if Hostinger lets the browser cache index.html/sw.js/manifest.webmanifest
# for any length of time: those are the files that announce a new build
# exists, so they must always be re-fetched. Hashed files under /assets/ get
# the opposite policy (cache forever) in public/assets/.htaccess — every Vite
# build gives them a new filename, so there's never a stale copy to evict.
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "^(index\.html|sw\.js|registerSW\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>
