# Copia este archivo a ".env" y pon tu Client ID de Google para activar el
# botón "Registrarte con Google" en /unlock.
#
# Cómo conseguirlo (gratis, sin VPS ni backend):
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un proyecto (o usa uno existente).
# 3. "Crear credenciales" -> "ID de cliente de OAuth" -> tipo "Aplicación web".
# 4. En "Orígenes de JavaScript autorizados" agrega la URL donde corre el
#    sitio, por ejemplo http://localhost:5173 y tu dominio en producción.
# 5. Copia el "Client ID" (termina en .apps.googleusercontent.com) aquí abajo.
VITE_GOOGLE_CLIENT_ID=

# Supabase: activa cuentas reales (email, Google, Facebook), llaves guardadas
# en la nube, comentarios en los cursos y sincronización de progreso.
#
# Cómo conseguirlo (gratis):
# 1. Crea un proyecto en https://supabase.com
# 2. En el SQL Editor del proyecto corre el archivo supabase/schema.sql
# 3. Ve a "Project Settings" -> "API" y copia "Project URL" y "anon public key"
# 4. (Opcional) Activa Google/Facebook en "Authentication" -> "Providers"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pon esto en "true" solo después de configurar el provider de Facebook en
# Supabase (Authentication -> Providers -> Facebook). Mientras tanto el botón
# "Continuar con Facebook" se mantiene oculto.
VITE_ENABLE_FACEBOOK_LOGIN=
